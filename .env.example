# Copy this file to `.env` and fill in your keys, OR set these as exports
# in ~/.zshenv. See README.md for details on both approaches.

# --- Required ----------------------------------------------------------------

# WaveSpeed API key — get from https://wavespeed.ai after signup
WAVESPEED_API_KEY=

# --- Choose ONE of the two Claude auth methods below ------------------------

# Option A (recommended): OAuth token tied to your Claude subscription.
# Generate with: claude setup-token
# Lasts ~1 year. Uses your Pro/Max/Team/Enterprise plan's included usage.
CLAUDE_CODE_OAUTH_TOKEN=

# Option B: standard Anthropic API key (pay-per-token, separate billing).
# Only used if CLAUDE_CODE_OAUTH_TOKEN is not set.
# ANTHROPIC_API_KEY=
